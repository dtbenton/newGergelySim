print(jump_height[2,1], sep = "\t", quote = FALSE, row.names = FALSE)
# goal
cat(paste("(Goal_OUT)", sep="\t"))
print(goal[2,1], sep = "\t", quote = FALSE, row.names = FALSE)
cat(paste(";", sep="\t"))
cat("\n")
l3 = l3+1
}
