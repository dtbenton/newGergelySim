c("I" = "In-Person", "O"="Online"))
D_tall$location = as.factor(D_tall$location)
D_tall$ask_order = as.factor(D_tall$ask_order)
D_tall$same_box = revalue(x = as.factor(D_tall$same_box),
c("1" = "Same Box", "0"="Different Box"))
D_tall$experimental_vs_control_order = as.factor(D_tall$experimental_vs_control_order)
# mean center age
D_tall$age_mc = D_tall$age -mean(D_tall$age, na.rm = TRUE)
# liberal and conservative coding schemes
D_tall$probGenCat_conserv = rep(NA_character_, nrow(D_tall))
for (i in seq_len(nrow(D_tall))) {
p = D_tall$probability[i]
g = D_tall$prob_generalization[i]
# Skip/ignore rows with NAs
if (is.na(p) || is.na(g)) next
if (p == "A" & g == "E") {
D_tall$probGenCat_conserv[i] = "Correct"
} else if (p == "B" & g == "D") {
D_tall$probGenCat_conserv[i] = "Correct"
} else if (p == "C" & g == "C") {
D_tall$probGenCat_conserv[i] = "Correct"
} else if (p == "D" & g == "B") {
D_tall$probGenCat_conserv[i] = "Correct"
} else if (p == "E" & g == "A") {
D_tall$probGenCat_conserv[i] = "Correct"
} else {
D_tall$probGenCat_conserv[i] = "Incorrect"
}
}
D_tall$probGenCat_conserv = as.factor(D_tall$probGenCat_conserv)
D_tall$probGenCat_lib = rep(NA_character_, nrow(D_tall))
for (i in seq_len(nrow(D_tall))) {
p = D_tall$probability[i]
g = D_tall$prob_generalization[i]
# Skip/ignore rows with NAs
if (is.na(p) || is.na(g)) next
if (p == "A" & g == "E" ||  g == "D") {
D_tall$probGenCat_lib[i] = "Correct"
} else if (p == "B" & g == "D" || g == "E") {
D_tall$probGenCat_lib[i] = "Correct"
} else if (p == "C" & g == "C" || g == "B" || g == "D") {
D_tall$probGenCat_lib[i] = "Correct"
} else if (p == "D" & g == "B" || g == "A") {
D_tall$probGenCat_lib[i] = "Correct"
} else if (p == "E" & g == "A" || g == "B") {
D_tall$probGenCat_lib[i] = "Correct"
} else {
D_tall$probGenCat_lib[i] = "Incorrect"
}
}
D_tall$probGenCat_lib = as.factor(D_tall$probGenCat_lib)
D_tall$probability = NULL
D_tall$prob_generalization = NULL
D_tall$age_cat = as.factor(D_tall$age_cat)
D_tall$age = as.numeric(D_tall$age)
# create columns to determine whether each condition answers in accordance with their condition
D_tall$mostNotNone = ifelse(D_tall$prob_generalization=="D"|D_tall$prob_generalization=="E", "most not + none", "everything else")
D_tall$allMost = ifelse(D_tall$prob_generalization=="A"|D_tall$prob_generalization=="B", "all + most", "everything else")
D_tall$average = ifelse(D_tall$prob_generalization=="C", "average", "everything else")
# create two dataframes
D_conserv = subset(D_tall, ! probGenCat_conserv %in% c("Incorrect"))
D_lib = subset(D_tall, ! probGenCat_lib %in% c("Incorrect"))
# create condition subsets
D_0_perc = subset(D_tall, ! condition %in% c("20% Condition", "50% Condition", "80% Condition", "100% Condition"))
D_20_perc = subset(D_tall, ! condition %in% c("0% Condition", "50% Condition", "80% Condition", "100% Condition"))
D_50_perc = subset(D_tall, ! condition %in% c("0% Condition", "20% Condition", "80% Condition", "100% Condition"))
D_80_perc = subset(D_tall, ! condition %in% c("0% Condition", "20% Condition", "50% Condition",  "100% Condition"))
D_100_perc = subset(D_tall, ! condition %in% c("0% Condition", "20% Condition", "50% Condition", "80% Condition"))
# get counts for choice
table(D_tall$choice)
levels(D_lib$prob_generalization_nominal)
D_lib$prob_generalization_nominal = factor(D_lib$prob_generalization_nominal,
levels = c("None", "Most Not", "Half", "Most", "All"),
ordered = TRUE)
levels(D_lib$prob_generalization_nominal)
ordinal.model = polr(prob_generalization_nominal ~ condition, data = D_lib, Hess = TRUE)
summary(ordinal.model)
exp(ordinal.model$coefficients)
ctable = coef(summary(ordinal.model))
xtabs(~condition+prob_generalization_nominal, data = D_lib)
exp(confint(ordinal.model, method = "Wald"))
ctable = coef(summary(ordinal.model))
# compute p-values
p = pnorm(abs(ctable[, "t value"]), lower.tail = FALSE) * 2
ctable = cbind(ctable, "p value" = p)
ctable
exp(confint(ordinal.model, method = "Wald"))
exp(ordinal.model$coefficients)
names(D_lib)
glmer.new.iv = glmer(choice~(age_mc+prob_generalization_nominal+trialType+same_box)^4+
(1|ID), family=binomial,
data=D_lib[D_lib$object_type=="compound",])
Anova(glmer.new.iv)
D_lib$base_rate_num = c(0,20,50,80,100)[match(D_lib$base_rate_factor,
c("0% Condition","20% Condition",
"50% Condition",
"80% Condition",
"100% Condition"))]
levels(D_lib$condition)
