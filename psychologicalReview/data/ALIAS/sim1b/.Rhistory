match(D_lib$condition,
c("0% Condition", "20% Condition", "50% Condition", "80% Condition", "100% Condition"))
]
mod_linear <- polr(prob_generalization_nominal ~ condition_num,
data = D_lib,
Hess = TRUE)
mod_cat <- polr(prob_generalization_nominal ~ condition,
data = D_lib,
Hess = TRUE)
anova(mod_linear, mod_cat)
