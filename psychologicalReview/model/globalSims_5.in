	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation3/sim3c/pretrain.ex" -e PERMUTED

	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation3/sim3c/sim3cExpHab.ex" 
