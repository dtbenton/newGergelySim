	addGroup Object_Right_Animate_Status_OUT 2 OUTPUT
	addGroup Grid_OUT 5 OUTPUT 
	addGroup Grid_Position_OUT 3 OUTPUT
	addGroup Jump_Height_OUT 5 OUTPUT
	addGroup Motion_OUT 6 OUTPUT
	addGroup Motion_Type_OUT 2 OUTPUT
	addGroup Goal_OUT 1 OUTPUT  
	addGroup Clearance_OUT 3 OUTPUT


	# connect groups (input -> hidden -> output)
	connectGroups {Object_Left_IN Object_Right_IN Object_Left_Animate_Status_IN Object_Right_Animate_Status_IN Grid_Position_IN Motion_IN Motion_Type_IN Goal_IN Clearance_IN Jump_Height_IN Grid_IN context} hidden {Object_Left_OUT Object_Right_OUT Object_Left_Animate_Status_OUT Object_Right_Animate_Status_OUT Grid_Position_OUT Motion_OUT Motion_Type_OUT Goal_OUT Clearance_OUT Jump_Height_OUT Grid_OUT}

