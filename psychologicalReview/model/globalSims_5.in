	set condition [list hab control hab]
	set ifEvent [list causal causalControl noncausal]
	set habEvent [list sim5dExpHab sim5dCntrlHab sim5dExpHabIneff]
	set testEvent [list sim5dTest sim5dTest sim5dTest]
	set trainingEpochs [list 8 9 10 11 12]
	set pretrainingEpochs [list 225]
	


	# define loop

	foreach stud $study cond $condition hEvent $habEvent tEvent $testEvent iEvent $ifEvent fldr $folder {
		set workingdirectory "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/data/ALIASnoSalience/sim5d/$fldr"
		cd $workingdirectory
			foreach tEpochs $trainingEpochs {
				foreach epochs $pretrainingEpochs {
					testNetwork 20 pretrain $epochs $hEvent $tEpochs $tEvent Study_${stud}_pEpochs_${epochs}_${cond}_habEvent_${hEvent}_tEpochs_${tEpochs}.txt $iEvent
			} 
		}
	}
}




# Simulation 6: Predictions simulation (see R file in "simulation 6" for deets)
# 12 mos
proc gsSim_sim6 {} {
	addNet gsSim6 -i 8

	# input groups
	addGroup Object_Left_IN 82 INPUT OUT_NOISE 
	addGroup Object_Right_IN 82 INPUT  OUT_NOISE
	addGroup Object_Left_Animate_Status_IN 2 INPUT OUT_NOISE 
	addGroup Object_Right_Animate_Status_IN 2 INPUT  OUT_NOISE
	addGroup Grid_IN 5 INPUT  OUT_NOISE
	addGroup Grid_Position_IN 3 INPUT OUT_NOISE 
	addGroup Jump_Height_IN 5 INPUT OUT_NOISE 
	addGroup Motion_IN 6 INPUT OUT_NOISE
	addGroup Motion_Type_IN 2 INPUT OUT_NOISE
	addGroup Goal_IN 1 INPUT OUT_NOISE
	addGroup Clearance_IN 3 INPUT OUT_NOISE

	# hidden group (# there are necessarily fewer hidden units than there are input and output units)
	addGroup context 50 ELMAN
	addGroup hidden 50 RELU
	
	# noise parameters
	noiseType Object_Left_IN -range 0.3
	noiseType Object_Right_IN -range 0.3
	noiseType Object_Left_Animate_Status_IN -range 0.3
	noiseType Object_Right_Animate_Status_IN -range 0.3
	noiseType Grid_IN -range 0.3
	noiseType Grid_Position_IN -range 0.3
	noiseType Jump_Height_IN -range 0.3
	noiseType Motion_IN -range 0.3
	noiseType Motion_Type_IN -range 0.3
	noiseType Goal_IN -range 0.3
	noiseType Clearance_IN -range 0.3
		

	# output group
	addGroup Object_Left_OUT 82 OUTPUT 
	addGroup Object_Right_OUT 82 OUTPUT 
	addGroup Object_Left_Animate_Status_OUT 2 OUTPUT
	addGroup Object_Right_Animate_Status_OUT 2 OUTPUT
	addGroup Grid_OUT 5 OUTPUT 
	addGroup Grid_Position_OUT 3 OUTPUT
	addGroup Jump_Height_OUT 5 OUTPUT
	addGroup Motion_OUT 6 OUTPUT
	addGroup Motion_Type_OUT 2 OUTPUT
	addGroup Goal_OUT 1 OUTPUT  
	addGroup Clearance_OUT 3 OUTPUT


	# connect groups (input -> hidden -> output)
	connectGroups {Object_Left_IN Object_Right_IN Object_Left_Animate_Status_IN Object_Right_Animate_Status_IN Motion_IN Goal_IN Clearance_IN  Jump_Height_IN Motion_Type_IN context} hidden {Object_Left_OUT Object_Right_OUT Object_Left_Animate_Status_OUT Object_Right_Animate_Status_OUT Motion_OUT Goal_OUT Clearance_OUT Jump_Height_OUT Motion_Type_OUT}

	connectGroups {Grid_IN Grid_Position_IN} hidden -type barrierSalience
	connectGroups hidden {Grid_OUT Grid_Position_OUT} -type barrierSalience

	elmanConnect hidden context

	deleteGroups bias

	# training examples
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation6/pretrain.ex" -e PERMUTED

	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation6/sim6ExpHab.ex" 
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation6/sim6Test.ex"

	# set learning and display parameters
	setObj learningRate 0.1
	setObj momentum	    0
	setObj batchSize    0
	setObj numUpdates   10
	setObj randRange 0.1
	setObj reportInterval 0
	setObj pseudoExampleFreq 1

	# create a function that gets the error for each test example
	proc saveActivations {fname} { 
		set outfile [open $fname a] 
		puts $outfile "[getObj currentExample.num] [getObj currentExample.name] " nonewline 
		puts $outfile [getObj exampleError]
		close $outfile 
	}

	proc testAllFinalActs {fname} { 
		resetExampleSet [getObj testingSet.name] 
		set nex [getObj testingSet.numExamples] 
		for {set i 0} {$i < $nex} {incr i} {
			doExample -set [getObj testingSet.name]
			saveActivations $fname
		}
	}

	proc testNetwork {n train trainNum train2 trainNum2 test fname} {
		for {set i 0} {$i < $n} {incr i} {
			resetNet
			useTrainingSet $train
			train $trainNum
			useTrainingSet $train2
			train $trainNum2
			useTestingSet $test
			testAllFinalActs $fname
		}
	}


	# define lists for looping
	set study [list sim6]
	set habEvent [list sim6ExpHab]
	set testEvent [list sim6Test]
	set pretrainingEpochs [list 900]
	set trainingEpochs [list 8 9 10 11 12]


	# define loop

	foreach stud $study hEvent $habEvent tEvent $testEvent {
		set workingdirectory "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/data/ALIAS/prediction/sim6"
		cd $workingdirectory
		foreach tEpochs $trainingEpochs {
			foreach epochs $pretrainingEpochs {
				testNetwork 20 pretrain $epochs $hEvent $tEpochs $tEvent Study_${stud}_pEpochs_${epochs}_tEpochs_${tEpochs}.txt
			}
		}
	}
}



# Simulation 7:  loosely based on Skerry, Carey, & Spelke [2013]: Exp1 Exp2 Exp5;
# Causally effective curved motion experience during action phase prior to standard habituation (to make curved more familiar than straight)
# 3 mos

proc gsSim_sim7 {} {
	addNet gsSim_7 -i 8

	# input groups
	addGroup Object_Left_IN 82 INPUT OUT_NOISE 
	addGroup Object_Right_IN 82 INPUT  OUT_NOISE
	addGroup Object_Left_Animate_Status_IN 2 INPUT OUT_NOISE 
	addGroup Object_Right_Animate_Status_IN 2 INPUT  OUT_NOISE
	addGroup Grid_IN 5 INPUT  OUT_NOISE
	addGroup Grid_Position_IN 3 INPUT OUT_NOISE 
	addGroup Jump_Height_IN 5 INPUT OUT_NOISE 
	addGroup Motion_IN 6 INPUT OUT_NOISE
	addGroup Motion_Type_IN 2 INPUT OUT_NOISE
	addGroup Goal_IN 1 INPUT OUT_NOISE
	addGroup Clearance_IN 3 INPUT OUT_NOISE

	# hidden group (# there are necessarily fewer hidden units than there are input and output units)
	addGroup context 10 ELMAN
	addGroup hidden 10 RELU
	
	# noise parameters
	noiseType Object_Left_IN -range 0.3
	noiseType Object_Right_IN -range 0.3
	noiseType Object_Left_Animate_Status_IN -range 0.3
	noiseType Object_Right_Animate_Status_IN -range 0.3
	noiseType Grid_IN -range 0.3
	noiseType Grid_Position_IN -range 0.3
	noiseType Jump_Height_IN -range 0.3
	noiseType Motion_IN -range 0.3
	noiseType Motion_Type_IN -range 0.3
	noiseType Goal_IN -range 0.3
	noiseType Clearance_IN -range 0.3
		
	# output group
	addGroup Object_Left_OUT 82 OUTPUT 
	addGroup Object_Right_OUT 82 OUTPUT 
	addGroup Object_Left_Animate_Status_OUT 2 OUTPUT 
	addGroup Object_Right_Animate_Status_OUT 2 OUTPUT 
	addGroup Grid_OUT 5 OUTPUT 
	addGroup Grid_Position_OUT 3 OUTPUT 
	addGroup Jump_Height_OUT 5 OUTPUT 
	addGroup Motion_OUT 6 OUTPUT 
	addGroup Motion_Type_OUT 2 OUTPUT 
	addGroup Goal_OUT 1 OUTPUT 
	addGroup Clearance_OUT 3 OUTPUT


	# connect groups (input -> hidden -> output)
	connectGroups {Object_Left_IN Object_Right_IN Object_Left_Animate_Status_IN Object_Right_Animate_Status_IN Motion_IN Goal_IN Clearance_IN  Jump_Height_IN Motion_Type_IN context} hidden {Object_Left_OUT Object_Right_OUT Object_Left_Animate_Status_OUT Object_Right_Animate_Status_OUT Motion_OUT Goal_OUT Clearance_OUT Jump_Height_OUT Motion_Type_OUT}

	connectGroups {Grid_IN Grid_Position_IN} hidden -type barrierSalience
	connectGroups hidden {Grid_OUT Grid_Position_OUT} -type barrierSalience

	elmanConnect hidden context

	deleteGroups bias

	# training examples
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation7/pretrain.ex" -e PERMUTED

	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation7/sim7ExpHab.ex" 
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation7/sim7ActionPhase.ex"
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation7/sim7ActionPhaseIneff.ex"
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation7/sim7CntrlHab.ex" 
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation7/sim7Test.ex"

	# set learning and display parameters
	setObj learningRate 0.0.075
	setObj momentum	    0
	setObj batchSize    0
	setObj numUpdates   10
	setObj randRange 0.1
	setObj reportInterval 0
	setObj pseudoExampleFreq 1
	setObj weightDecay 0.175

	# create a function that gets the error for each test example
	proc saveActivations {fname} { 
		set outfile [open $fname a] 
		puts $outfile "[getObj currentExample.num] [getObj currentExample.name] " nonewline 
		puts $outfile [getObj exampleError]
		close $outfile 
	}

	proc testAllFinalActs {fname} { 
		resetExampleSet [getObj testingSet.name] 
		set nex [getObj testingSet.numExamples] 
		for {set i 0} {$i < $nex} {incr i} {
			doExample -set [getObj testingSet.name]
			saveActivations $fname
		}
	}

	proc testNetwork {n train trainNum train2 trainNum2 train3 trainNum3 test fname ifEvent} {
		if {$ifEvent == "effective" || $ifEvent == "effectiveControl"} {
			for {set i 0} {$i < $n} {incr i} {
				resetNet
				
				
				setObj learningRate 0.075
				useTrainingSet $train
				train $trainNum
				
				
				setObj learningRate 0.175
				useTrainingSet $train2
				train $trainNum2
				setObj learningRate 0.075
				useTrainingSet $train3
				train $trainNum3
				useTestingSet $test
				testAllFinalActs $fname
			}
		} else {
			for {set i 0} {$i < $n} {incr i} {
				resetNet
				
				
				setObj learningRate 0.075
				useTrainingSet $train
				train $trainNum
				
				setObj learningRate 0.075
				useTrainingSet $train2
				train $trainNum2
				useTrainingSet $train3
				train $trainNum3
				useTestingSet $test
				testAllFinalActs $fname
			}
		}
	}




	# define lists for looping
	set study [list sim7 sim7 sim7]
	set folder [list effective effective ineffective]
	set condition [list hab control hab]
	set actionPhaseEvent [list sim7ActionPhase sim7ActionPhase sim7ActionPhaseIneff]
	set ifEvent [list effective effectiveControl ineffective]
	set habEvent [list sim7ExpHab sim7CntrlHab sim7ExpHab]
	set testEvent [list sim7Test sim7Test sim7Test]
	set actionPhaseEpochs [list 8 9 10 11 12]
	set trainingEpochs [list 8 9 10 11 12]
	set pretrainingEpochs [list 225]
	


	# define loop

	foreach stud $study cond $condition hEvent $habEvent tEvent $testEvent aEvent $actionPhaseEvent iEvent $ifEvent fldr $folder {
		set workingdirectory "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/data/ALIAS/prediction/sim7/$fldr"
		cd $workingdirectory
			foreach apEpochs $actionPhaseEpochs tEpochs $trainingEpochs {
				foreach epochs $pretrainingEpochs {
					testNetwork 20 pretrain $epochs $aEvent $apEpochs $hEvent $tEpochs $tEvent Study_${stud}_pEpochs_${epochs}_${cond}_habEvent_${hEvent}_tEpochs_${tEpochs}_actionEpochs_${apEpochs}.txt $iEvent
			} 
		}
	}
}



