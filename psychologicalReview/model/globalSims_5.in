	addGroup Clearance_OUT 3 OUTPUT


	# connect groups (input -> hidden -> output)
	connectGroups {Object_Left_IN Object_Right_IN Object_Left_Animate_Status_IN Object_Right_Animate_Status_IN Motion_IN Goal_IN Clearance_IN Jump_Height_IN Motion_Type_IN context} hidden {Object_Left_OUT Object_Right_OUT Object_Left_Animate_Status_OUT Object_Right_Animate_Status_OUT Motion_OUT Goal_OUT Clearance_OUT Jump_Height_OUT Motion_Type_OUT}

	connectGroups {Grid_IN Grid_Position_IN} hidden -type barrierSalience
	connectGroups hidden {Grid_OUT Grid_Position_OUT} -type barrierSalience

	elmanConnect hidden context

	deleteGroups bias

	# training examples
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/pretrain_100_0.ex" -e PERMUTED
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/pretrain_90_10.ex" -e PERMUTED
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/pretrain_80_20.ex" -e PERMUTED
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/pretrain_70_30.ex" -e PERMUTED
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/pretrain_60_40.ex" -e PERMUTED
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/pretrain_50_50.ex" -e PERMUTED

	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/sim1bExpHab.ex" 
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/sim1bCntrlHab.ex" 
	loadExamples "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/model/simulation1b/sim1bTest.ex"

	# set learning and display parameters
	setObj learningRate 0.1
	setObj momentum	    0
	setObj batchSize    0
	setObj numUpdates   10
	setObj randRange 0.1
	setObj reportInterval 0
	setObj pseudoExampleFreq 1

	# create a function that gets the error for each test example
	proc saveActivations {fname} { 
		set outfile [open $fname a] 
		puts $outfile "[getObj currentExample.num] [getObj currentExample.name] " nonewline 
		puts $outfile [getObj exampleError]
		close $outfile 
	}

	proc testAllFinalActs {fname} { 
		resetExampleSet [getObj testingSet.name] 
		set nex [getObj testingSet.numExamples] 
		for {set i 0} {$i < $nex} {incr i} {
			doExample -set [getObj testingSet.name]
			saveActivations $fname
		}
	}

	proc testNetwork {n train trainNum train2 trainNum2 test fname} {
		for {set i 0} {$i < $n} {incr i} {
			resetNet
			useTrainingSet $train
			train $trainNum
			useTrainingSet $train2
			train $trainNum2
			useTestingSet $test
			testAllFinalActs $fname
		}
	}


	# define lists for looping
	set condition [list pretrain5050]
	set pretrain [list pretrain_50_50]
	set habEvent [list sim1bExpHab sim1bCntrlHab] 
	set testEvent [list sim1bTest sim1bTest]
	set pretrainingEpochs [list 900]
	set trainingEpochs [list 8 9 10 11 12]



	# define loop
	foreach cond $condition pEvent $pretrain {
		set workingdirectory "C:/Users/bentod2/Documents/projects/current/NEWgergliuSims/psychologicalReview/data/ALIAS/sim1b/$cond"
		cd $workingdirectory
		foreach hEvent $habEvent tEvent $testEvent {
			foreach epochs $pretrainingEpochs {
				foreach tEpochs $trainingEpochs {
				testNetwork 20 $pEvent $epochs $hEvent $tEpochs $tEvent pEpochs_${epochs}_tEpochs_${tEpochs}_condition_${cond}_testEvent_${tEvent}_habEvent_${hEvent}.txt
				}
			}
		}
	}
}



