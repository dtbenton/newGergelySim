# Simulation 5 (based loosely on Skerry, Carey, & Spelke [2013])
# Author: Deon T. Benton

addNet gsSim -i 8

# # input groups
	addGroup Object_Left_IN 82 INPUT OUT_NOISE 
	addGroup Object_Right_IN 82 INPUT  OUT_NOISE
	addGroup Object_Left_Animate_Status_IN 2 INPUT OUT_NOISE 
	addGroup Object_Right_Animate_Status_IN 2 INPUT  OUT_NOISE
	addGroup Grid_IN 5 INPUT  OUT_NOISE
	addGroup Grid_Position_IN 3 INPUT OUT_NOISE 
	addGroup Jump_Height_IN 5 INPUT OUT_NOISE 
	addGroup Motion_IN 6 INPUT OUT_NOISE
	addGroup Motion_Type_IN 2 INPUT OUT_NOISE
	addGroup Goal_IN 1 INPUT OUT_NOISE
	addGroup Clearance_IN 3 INPUT OUT_NOISE

	# hidden group (# there are necessarily fewer hidden units than there are input and output units)
	addGroup context 10 ELMAN
	addGroup hidden 10 RELU
	
	# noise parameters
	noiseType Object_Left_IN -range 0.3
	noiseType Object_Right_IN -range 0.3
	noiseType Object_Left_Animate_Status_IN -range 0.3
	noiseType Object_Right_Animate_Status_IN -range 0.3
	noiseType Grid_IN -range 0.3
	noiseType Grid_Position_IN -range 0.3
	noiseType Jump_Height_IN -range 0.3
	noiseType Motion_IN -range 0.3
	noiseType Motion_Type_IN -range 0.3
	noiseType Goal_IN -range 0.3
	noiseType Clearance_IN -range 0.3
	
	

	# output group
	addGroup Object_Left_OUT 82 OUTPUT 
	addGroup Object_Right_OUT 82 OUTPUT 
	addGroup Object_Left_Animate_Status_OUT 2 OUTPUT 
	addGroup Object_Right_Animate_Status_OUT 2 OUTPUT 
	addGroup Grid_OUT 5 OUTPUT 
	addGroup Grid_Position_OUT 3 OUTPUT 
	addGroup Jump_Height_OUT 5 OUTPUT 
	addGroup Motion_OUT 6 OUTPUT 
	addGroup Motion_Type_OUT 2 OUTPUT 
	addGroup Goal_OUT 1 OUTPUT 
	addGroup Clearance_OUT 3 OUTPUT 


# connect groups (input -> hidden -> output)
	connectGroups {Object_Left_IN Object_Right_IN Object_Left_Animate_Status_IN Object_Right_Animate_Status_IN Motion_IN Goal_IN Clearance_IN  Jump_Height_IN Motion_Type_IN context} hidden {Object_Left_OUT Object_Right_OUT Object_Left_Animate_Status_OUT Object_Right_Animate_Status_OUT Motion_OUT Goal_OUT Clearance_OUT Jump_Height_OUT Motion_Type_OUT}

	connectGroups {Grid_IN Grid_Position_IN} hidden -type barrierSalience
	connectGroups hidden {Grid_OUT Grid_Position_OUT} -type barrierSalience

	elmanConnect hidden context

	deleteGroups bias

# training examples
	loadExamples pretrain.ex -s pretrain -e PERMUTED 
	loadExamples sim5aActionPhase.ex
	loadExamples sim5aExpHab.ex 
	loadExamples sim5aCntrlHab.ex 
	loadExamples sim5aTest.ex
	loadExamples sim5aCntrlTest.ex


# set learning and display parameters
setObj learningRate 0.0001
setObj momentum	    0
setObj batchSize    0
setObj numUpdates   100
setObj reportInterval 1
setObj unitCellSize 12
setObj linkCellSize 10
setObj randRange 0.1
setObj pseudoExampleFreq 1

	
resetPlot 
plotRow 10 b 1 n Object_Left_OUT 10 b 4 rnext Object_Right_OUT 10
plotRow 2 b 1 n Object_Left_Animate_Status_OUT 2 b 20 n Object_Right_Animate_Status_OUT 2
plotRow 2 b 10 n Grid_Position_OUT 3
plotRow 2 b 10 n Motion_Type_OUT 8 b 4 rnext Motion_OUT 6 
plotRow 2 b 10 n Grid_OUT 6
plotRow 2 b 10 n Jump_Height_OUT 6 b 4 rnext Clearance_OUT 3
plotRow 7 b 8 n hidden 10 
plotRow 7 b 10 n context 10 
plotRow 2 b 10 n Jump_Height_IN 6 b 4 rnext Clearance_IN 3
plotRow 2 b 10 n Grid_IN 6
plotRow 2 b 10 n Motion_Type_IN 8 b 4 rnext Motion_IN 6 
plotRow 2 b 10 n Grid_Position_IN 3
plotRow 2 b 1 n Object_Left_Animate_Status_IN 2 b 20 n Object_Right_Animate_Status_IN 2
plotRow 10 b 1 n Object_Left_IN 10 b 4 rnext Object_Right_IN 10
drawUnits
viewUnits

